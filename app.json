{
  "expo": {
    "name": "FlashMedic",
    "slug": "flashmedic",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flashmedic",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dk.flashmedic.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "dk.flashmedic.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#2F8F9D",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/image_2026-03-25_113448889.png",
          "imageWidth": 360,
          "resizeMode": "contain",
          "backgroundColor": "#168fa2",
          "dark": {
            "backgroundColor": "#168fa2"
          }
        }
      ],
      "expo-mail-composer",
      "expo-font",
      "expo-web-browser",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fde9e5e8-1011-4770-aa35-86f54d59f94f"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/fde9e5e8-1011-4770-aa35-86f54d59f94f"
    }
  }
}
