{
  "cli": {
    "version": ">= 16.28.0",
    "requireCommit": true,
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "alpha",
        "releaseStatus": "completed"
      },
      "ios": {
        "ascAppId": "6761177814"
      }
    }
  }
}
